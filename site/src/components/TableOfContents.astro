---
/**
 * TableOfContents override (right-rail "On This Page").
 *
 * Several pages render their section headings from a server component / island
 * (the Software & Databases catalogs, Talks, Awesome Lists, and the Primer hubs)
 * rather than as Markdown headings, so Starlight can't collect them into the
 * native "On This Page". Here we inject those sections into the route's
 * `toc.items` (keeping the leading "Overview" item) and then render Starlight's
 * own TableOfContents — so the list, styling, and scroll-spy all come for free.
 * The anchors target the section-heading ids those components render (shared
 * slug helpers). See MobileTableOfContents.astro for the companion override and
 * toc-inject.ts for the shared, idempotent injection.
 *
 * Every other route renders Starlight's default TOC unchanged.
 */
import Default from '@astrojs/starlight/components/TableOfContents.astro';
import { islandTocItems } from '../lib/toc-inject';

const route = Astro.locals.starlightRoute;
const path = Astro.url.pathname.replace(/\/$/, '');

if (route.toc && route.toc.items.length > 0) {
  const injected = islandTocItems(path, route.toc.items[0]);
  if (injected) route.toc.items = injected;
}
---

<Default />
