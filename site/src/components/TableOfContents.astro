---
/**
 * TableOfContents override.
 *
 * The Software and Databases catalogs are interactive islands, so their
 * application-area headings aren't Markdown headings and Starlight can't collect
 * them into the native "On This Page". Here we inject those areas into the
 * route's `toc.items` (keeping the leading "Overview" item) and then render
 * Starlight's own TableOfContents — so the right-rail list, styling, and
 * scroll-spy all come for free. The anchors target the group-heading ids the
 * CatalogBrowser island renders (shared `groupSlug`).
 *
 * Every other route renders Starlight's default TOC unchanged.
 */
import Default from '@astrojs/starlight/components/TableOfContents.astro';
import { catalogGroups, type CatalogKind } from '../lib/catalog-groups';

const route = Astro.locals.starlightRoute;
const path = Astro.url.pathname.replace(/\/$/, '');
const kind: CatalogKind | null = path.endsWith('/software')
  ? 'software'
  : path.endsWith('/databases')
    ? 'databases'
    : null;

if (kind && route.toc && route.toc.items.length > 0) {
  const overview = route.toc.items[0]; // PAGE_TITLE_ID / "Overview"
  route.toc.items = [
    overview,
    ...catalogGroups(kind).map((g) => ({
      depth: 2,
      slug: g.slug,
      text: g.label,
      children: [],
    })),
  ];
}
---

<Default />
