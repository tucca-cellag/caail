---
const steps = [
  { n: 1, title: 'New to the field?', desc: 'Read the cell-ag + AI overview and the research-area primers.' },
  { n: 2, title: 'Looking for a method?', desc: 'Open the Papers Explorer and filter the matrix by AI method or area.' },
  { n: 3, title: 'Need training data?', desc: 'Browse datasets by species, or benchmarks for model evaluation.' },
];
---
<section class="start">
  <h2 class="caail-display">Start here</h2>
  {steps.map((s) => (
    <div class="card"><span class="n caail-display">{s.n}</span><div><h3>{s.title}</h3><p>{s.desc}</p></div></div>
  ))}
</section>
<style>
  .start h2 { font-size: 1.05rem; color: var(--caail-primary); margin: 0 0 .8rem; }
  .card { display: flex; gap: .7rem; align-items: flex-start; border: 1px solid var(--caail-border); border-radius: 9px; padding: .8rem .9rem; margin-bottom: .55rem; }
  .n { font-size: 1rem; font-weight: 700; color: var(--caail-link); line-height: 1.2; }
  .card h3 { font-size: .85rem; margin: 0 0 .1rem; color: var(--caail-ink); }
  .card p { font-size: .76rem; color: var(--caail-muted); margin: 0; line-height: 1.4; }
</style>
