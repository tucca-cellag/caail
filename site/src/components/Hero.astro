---
import { Icon } from 'astro-icon/components';
import c from '../content/data/counts.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const stats = [
  { n: c.papers, label: 'Papers' },
  { n: c.software, label: 'Tools' },
  { n: c.databases, label: 'Databases' },
  { n: c.species, label: 'Species' },
  { n: c.researchAreas, label: 'Research areas' },
];
---
<section class="hero">
  <p class="eyebrow">Cellular Agriculture × Artificial Intelligence</p>
  <h1 class="caail-display">The curated library where AI meets cultivated meat.</h1>
  <p class="lede">
    Peer-reviewed papers, open-source software, databases, and the per-species datasets the
    field trains on — one navigable, openly-licensed map, with the canonical source in Markdown on GitHub.
  </p>

  <div class="cta-row">
    <a class="btn btn-primary" href={`${base}/papers/explorer/`}>
      <Icon name="ph:squares-four" />
      Open the Papers Explorer
    </a>
    <a class="btn btn-ghost" href="https://github.com/tucca-cellag/caail">
      <Icon name="ph:github-logo" />
      Browse on GitHub
    </a>
  </div>

  <dl class="stats">
    {stats.map((s) => (
      <div class="stat">
        <dt class="caail-display">{s.n}</dt>
        <dd>{s.label}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .hero { text-align: center; padding: 3.25rem 0 1.75rem; }
  .eyebrow { font-size: .72rem; letter-spacing: .15em; text-transform: uppercase; color: var(--caail-accent); font-weight: 700; margin: 0; }
  .hero h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); line-height: 1.05; color: var(--caail-primary); margin: .6rem auto .7rem; max-width: 18ch; font-weight: 700; letter-spacing: -0.01em; }
  .lede { font-size: 1rem; line-height: 1.6; color: var(--caail-muted); max-width: 58ch; margin: 0 auto 1.6rem; }

  .cta-row { display: flex; gap: .7rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
  .btn { display: inline-flex; align-items: center; gap: .5rem; border-radius: 999px; padding: .8rem 1.5rem; font-size: .92rem; font-weight: 600; text-decoration: none; border: 1.5px solid transparent; transition: background .15s, border-color .15s, color .15s, box-shadow .15s; }
  .btn [data-icon] { width: 1.15rem; height: 1.15rem; }
  .btn-primary { background: var(--caail-primary); color: #fff; box-shadow: 0 10px 26px -16px color-mix(in oklab, var(--caail-primary) 70%, transparent); }
  .btn-primary:hover { background: var(--caail-primary-hover); }
  .btn-ghost { background: var(--caail-bg); color: var(--caail-ink); border-color: var(--caail-border); }
  .btn-ghost:hover { border-color: var(--caail-link); color: var(--caail-link); }

  .stats { display: flex; gap: 2.2rem; justify-content: center; flex-wrap: wrap; margin: 0; padding-top: 1.25rem; border-top: 1px solid var(--caail-border); max-width: 46rem; margin-inline: auto; }
  .stat { display: flex; flex-direction: column; align-items: center; gap: .1rem; }
  .stat dt { font-size: 1.9rem; font-weight: 700; color: var(--caail-primary); line-height: 1; }
  .stat dd { margin: 0; font-size: .72rem; letter-spacing: .04em; text-transform: uppercase; color: var(--caail-muted); }

  @media (max-width: 30rem) {
    .stats { gap: 1.4rem 1.8rem; }
    .stat dt { font-size: 1.5rem; }
  }
</style>
