---
import { Icon } from 'astro-icon/components';
const queries = ['Bayesian optimization', 'media optimization', 'CHO cells', 'single-cell atlas', 'scaffolding'];
---
<section class="hero">
  <p class="eyebrow">Cellular Agriculture × Artificial Intelligence</p>
  <h1 class="caail-display">The curated library where AI meets cultivated meat.</h1>
  <p class="lede">
    Peer-reviewed papers, open-source software, databases, and the per-species datasets the
    field trains on — one navigable, openly-licensed map. The canonical source stays in Markdown on GitHub.
  </p>
  <button id="hero-search" class="bigsearch" type="button" aria-label="Search the library">
    <Icon name="ph:magnifying-glass" />
    <span>Search 193 papers, 70 tools, 71 databases, datasets…</span>
    <kbd>/</kbd>
  </button>
  <p class="qchips"><span>Try:</span>{queries.map((q) => <span class="qchip">{q}</span>)}</p>
</section>

<script>
  // Hero search opens Starlight's built-in site search (Pagefind). Progressive enhancement.
  document.getElementById('hero-search')?.addEventListener('click', () => {
    const btn = document.querySelector<HTMLButtonElement>('button[data-open-modal], site-search button');
    btn?.click();
  });
</script>

<style>
  .hero { text-align: center; padding: 2.5rem 0 1.5rem; }
  .eyebrow { font-size: .72rem; letter-spacing: .15em; text-transform: uppercase; color: var(--caail-accent); font-weight: 700; margin: 0; }
  .hero h1 { font-size: clamp(1.8rem, 4vw, 2.3rem); line-height: 1.13; color: var(--caail-primary); margin: .5rem auto .6rem; max-width: 19ch; font-weight: 600; }
  .lede { font-size: .95rem; line-height: 1.55; color: var(--caail-muted); max-width: 60ch; margin: 0 auto 1.25rem; }
  .bigsearch { display: flex; align-items: center; gap: .65rem; width: min(580px, 100%); margin: 0 auto; padding: .8rem 1rem;
    border: 1.5px solid var(--caail-primary); border-radius: 11px; background: var(--caail-bg); color: var(--caail-muted);
    font: inherit; font-size: .9rem; cursor: pointer; box-shadow: 0 8px 26px -16px color-mix(in oklab, var(--caail-primary) 45%, transparent); }
  .bigsearch [data-icon] { width: 1.25rem; height: 1.25rem; color: var(--caail-primary); }
  .bigsearch kbd { margin-left: auto; font-family: var(--caail-font-mono); font-size: .65rem; border: 1px solid var(--caail-border); border-radius: 5px; padding: .1rem .35rem; }
  .qchips { display: flex; gap: .5rem; justify-content: center; flex-wrap: wrap; margin-top: .8rem; font-size: .72rem; }
  .qchips > span:first-child { color: var(--caail-muted); align-self: center; }
  .qchip { color: var(--caail-ink); background: var(--caail-bg); border: 1px solid var(--caail-border); border-radius: 999px; padding: .3rem .65rem; }
</style>
