    "lint:papers": "tsx scripts/parser/lint-papers.ts",
    "db:bootstrap": "NODE_OPTIONS='--experimental-sqlite --no-warnings' tsx scripts/db/bootstrap.ts",
    "db:build": "NODE_OPTIONS='--experimental-sqlite --no-warnings' tsx scripts/db/build-db.ts",
    "db:export": "NODE_OPTIONS='--experimental-sqlite --no-warnings' tsx scripts/db/export-ndjson.ts",
    "db:reseed-axes": "NODE_OPTIONS='--experimental-sqlite --no-warnings' tsx scripts/db/reseed-axes.ts",
