{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm preview --port 4321",
      "startServerReadyPattern": "localhost:4321",
      "url": [
        "http://localhost:4321/caail/",
        "http://localhost:4321/caail/papers/explorer/"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:performance": ["warn", { "minScore": 0.9 }]
          }
        },
        {
          "matchingUrlPattern": "http://localhost:4321/caail/$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.9 }]
          }
        }
      ]
    }
  }
}
